@model SalaryApp.Models.ViewModels.SalaryEditViewModel

@{
    ViewData["Title"] = "Edit Salary";
}

<div class="row">
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-header">Employee</div>
            <div class="card-body">
                <div class="fw-semibold">@Model.EmployeeFirstName @Model.EmployeeLastName</div>
                <div class="text-muted small">@Model.PositionTitle</div>
                <div class="alert alert-info mt-3 mb-0">
                    <span class="small"><strong>Base Salary:</strong> @Model.BaseSalary.ToString("C")</span>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header">Salary Details</div>
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="EmployeeId" />

                    <div class="row g-3">
                        <div class="col-6">
                            <div class="form-group">
                                <label asp-for="PeriodStart" class="form-label">Period Start</label>
                                <input asp-for="PeriodStart" class="form-control" type="date" required />
                                <span asp-validation-for="PeriodStart" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="form-group">
                                <label asp-for="PeriodEnd" class="form-label">Period End</label>
                                <input asp-for="PeriodEnd" class="form-control" type="date" required />
                                <span asp-validation-for="PeriodEnd" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="form-group">
                                <label asp-for="Bonus" class="form-label">Bonus</label>
                                <div class="input-group">
                                    <span class="input-group-text">$</span>
                                    <input name="bonus" class="form-control" type="text" value="@Model.Bonus.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)" />
                                </div>
                                <span asp-validation-for="Bonus" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="form-group">
                                <label asp-for="Deduction" class="form-label">Deduction</label>
                                <div class="input-group">
                                    <span class="input-group-text">$</span>
                                    <input name="deduction" class="form-control" type="text" value="@Model.Deduction.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)" />
                                </div>
                                <span asp-validation-for="Deduction" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-1"></i> Save Changes
                        </button>
                        <a asp-controller="Employee" asp-action="Details" asp-route-id="@Model.EmployeeId" class="btn btn-secondary">
                            <i class="fas fa-arrow-left me-1"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        $(document).ready(function() {
            $('form').on('submit', function(e) {
                var startDate = new Date($('#PeriodStart').val());
                var endDate = new Date($('#PeriodEnd').val());
                if (startDate > endDate) {
                    e.preventDefault();
                    alert('Period start date cannot be after period end date.');
                }
            });
        });
    </script>
}
