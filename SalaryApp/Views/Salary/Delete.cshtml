@model SalaryApp.Models.Salary

@{
    ViewData["Title"] = "Delete Salary Record";
}

<div class="row">
    <div class="col-md-6">
        <div class="alert alert-danger mb-4">
            <i class="fas fa-exclamation-circle me-2"></i>
            <strong>Are you sure?</strong> This salary record will be permanently deleted.
        </div>

        <div class="card mb-4">
            <div class="card-header">Record Details</div>
            <div class="card-body">
                <dl class="row detail-list mb-0">
                    <dt class="col-5">Employee</dt>
                    <dd class="col-7">@Model.Employee.FirstName @Model.Employee.LastName</dd>

                    <dt class="col-5">Position</dt>
                    <dd class="col-7">@Model.Employee.Position.Title</dd>

                    <dt class="col-5">Period</dt>
                    <dd class="col-7">@Model.PeriodStart.ToShortDateString() – @Model.PeriodEnd.ToShortDateString()</dd>

                    <dt class="col-5">Base Salary</dt>
                    <dd class="col-7">@Model.Employee.Position.BaseSalary.ToString("C")</dd>

                    <dt class="col-5">Bonus</dt>
                    <dd class="col-7 text-success">+@Model.Bonus.ToString("C")</dd>

                    <dt class="col-5">Deduction</dt>
                    <dd class="col-7 text-danger">-@Model.Deduction.ToString("C")</dd>

                    <dt class="col-5">Total</dt>
                    <dd class="col-7 fw-semibold">@((Model.Employee.Position.BaseSalary + Model.Bonus - Model.Deduction).ToString("C"))</dd>
                </dl>
            </div>
        </div>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">
                    <i class="fas fa-trash me-1"></i> Delete Record
                </button>
                <a asp-controller="Employee" asp-action="Details" asp-route-id="@Model.EmployeeId" class="btn btn-secondary">
                    <i class="fas fa-arrow-left me-1"></i> Cancel
                </a>
            </div>
        </form>
    </div>
</div>
