@model SalaryApp.Models.ViewModels.SalaryCreateViewModel

@{
    ViewData["Title"] = "Add Salary Record";
}

<div class="row">
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-header">Employee</div>
            <div class="card-body">
                <div class="fw-semibold">@Model.EmployeeFirstName @Model.EmployeeLastName</div>
                <div class="text-muted small">@Model.PositionTitle</div>
                <div class="alert alert-info mt-3 mb-0">
                    <span class="small"><strong>Base Salary:</strong> @Model.BaseSalary.ToString("C")</span>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header">Salary Details</div>
            <div class="card-body">
                <form asp-action="Create" asp-route-employeeId="@Model.EmployeeId">
                    <div asp-validation-summary="All" class="text-danger small mb-3"></div>

                    <div class="row g-3">
                        <div class="col-6">
                            <div class="form-group">
                                <label asp-for="PeriodStart" class="form-label">Period Start</label>
                                <input asp-for="PeriodStart" class="form-control" type="date" />
                                <span asp-validation-for="PeriodStart" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="form-group">
                                <label asp-for="PeriodEnd" class="form-label">Period End</label>
                                <input asp-for="PeriodEnd" class="form-control" type="date" />
                                <span asp-validation-for="PeriodEnd" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="form-group">
                                <label asp-for="Bonus" class="form-label">Bonus</label>
                                <div class="input-group">
                                    <span class="input-group-text">$</span>
                                    <input asp-for="Bonus" class="form-control" type="number" step="0.01" min="0" />
                                </div>
                                <span asp-validation-for="Bonus" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="form-group">
                                <label asp-for="Deduction" class="form-label">Deduction</label>
                                <div class="input-group">
                                    <span class="input-group-text">$</span>
                                    <input asp-for="Deduction" class="form-control" type="number" step="0.01" min="0" />
                                </div>
                                <span asp-validation-for="Deduction" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-1"></i> Save Record
                        </button>
                        <a asp-controller="Employee" asp-action="Details" asp-route-id="@Model.EmployeeId" class="btn btn-secondary">
                            <i class="fas fa-arrow-left me-1"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const today = new Date();
            const firstDay = new Date(today.getFullYear(), today.getMonth(), 1);
            const lastDay = new Date(today.getFullYear(), today.getMonth() + 1, 0);
            document.getElementById('PeriodStart').value = firstDay.toISOString().split('T')[0];
            document.getElementById('PeriodEnd').value = lastDay.toISOString().split('T')[0];
        });
    </script>
}
