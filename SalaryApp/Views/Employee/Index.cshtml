@model IEnumerable<SalaryApp.Models.Employee>

@{
    ViewData["Title"] = "Employees";
}

<div class="page-header">
    <div></div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fas fa-plus me-1"></i> Add Employee
    </a>
</div>

<div class="table-responsive">
    <table class="table table-hover">
        <thead>
            <tr>
                <th>Name</th>
                <th>@Html.DisplayNameFor(model => model.Company)</th>
                <th>@Html.DisplayNameFor(model => model.Position)</th>
                <th>@Html.DisplayNameFor(model => model.Office)</th>
                <th>@Html.DisplayNameFor(model => model.HireDate)</th>
                <th style="width:1%">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <div class="emp-avatar" style="width:32px;height:32px;font-size:12px;">
                                @(item.FirstName?.Length > 0 ? item.FirstName[0].ToString() : "")@(item.LastName?.Length > 0 ? item.LastName[0].ToString() : "")
                            </div>
                            <span class="fw-medium">@item.FirstName @item.MiddleName @item.LastName</span>
                        </div>
                    </td>
                    <td>@Html.DisplayFor(modelItem => item.Company.Name)</td>
                    <td>@Html.DisplayFor(modelItem => item.Position.Title)</td>
                    <td>@Html.DisplayFor(modelItem => item.Office.Name)</td>
                    <td>@item.HireDate.ToString("dd/MM/yyyy")</td>
                    <td>
                        <div class="d-flex gap-1">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">
                                <i class="fas fa-eye"></i>
                            </a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">
                                <i class="fas fa-edit"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                                <i class="fas fa-trash"></i>
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
