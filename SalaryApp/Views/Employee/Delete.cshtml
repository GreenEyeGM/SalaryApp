@model SalaryApp.Models.Employee

@{
    ViewData["Title"] = "Terminate Employee";
}

<div class="row">
    <div class="col-md-6">
        <div class="alert alert-warning mb-4">
            <i class="fas fa-exclamation-triangle me-2"></i>
            <strong>Warning:</strong> This action will terminate the employee and cannot be undone.
        </div>

        <div class="card mb-4">
            <div class="card-header">Employee Information</div>
            <div class="card-body">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="emp-avatar">
                        @(Model.FirstName?.Length > 0 ? Model.FirstName[0].ToString() : "")@(Model.LastName?.Length > 0 ? Model.LastName[0].ToString() : "")
                    </div>
                    <div>
                        <div class="fw-semibold">@Model.FirstName @Model.MiddleName @Model.LastName</div>
                        <div class="text-muted small">@Model.Position?.Title</div>
                    </div>
                </div>
                <dl class="row detail-list mb-0">
                    <dt class="col-5">Company</dt>
                    <dd class="col-7">@Model.Company?.Name</dd>

                    <dt class="col-5">Office</dt>
                    <dd class="col-7">@Model.Office?.Name</dd>

                    <dt class="col-5">Hire Date</dt>
                    <dd class="col-7">@Model.HireDate.ToString("dd MMM yyyy")</dd>
                </dl>
            </div>
        </div>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">
                    <i class="fas fa-user-slash me-1"></i> Confirm Termination
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-arrow-left me-1"></i> Cancel
                </a>
            </div>
        </form>
    </div>
</div>
