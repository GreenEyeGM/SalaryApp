@{
    ViewData["Title"] = "Dashboard";
}

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <a href="/Companies" class="stat-card">
            <div class="stat-icon indigo">
                <i class="fas fa-building"></i>
            </div>
            <div>
                <div class="stat-label">Section</div>
                <div class="stat-title">Companies</div>
                <div class="stat-subtitle">Manage company information</div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a href="/Employee" class="stat-card">
            <div class="stat-icon emerald">
                <i class="fas fa-users"></i>
            </div>
            <div>
                <div class="stat-label">Section</div>
                <div class="stat-title">Employees</div>
                <div class="stat-subtitle">View and manage employee records</div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a href="/Salary" class="stat-card">
            <div class="stat-icon amber">
                <i class="fas fa-money-bill-wave"></i>
            </div>
            <div>
                <div class="stat-label">Section</div>
                <div class="stat-title">Salaries</div>
                <div class="stat-subtitle">Access and modify salary records</div>
            </div>
        </a>
    </div>
</div>

<div class="card">
    <div class="card-body text-center py-5">
        <div style="color: var(--accent); opacity: 0.25; font-size: 48px; margin-bottom: 16px;">
            <i class="fas fa-chart-line"></i>
        </div>
        <h5 class="fw-semibold mb-1">Welcome to SalaryApp</h5>
        <p class="text-muted small mb-0">A modern solution for managing employee salaries and company data.</p>
    </div>
</div>
